def celsius_to_fahrenheit(celsius):
    fahrenheit = (celsius * 9/5) + 32
    return fahrenheit
def fahrenheit_to_celsius(fahrenheit):
    celsius = (fahrenheit - 32) * 5/9
    return celsius
print("---  Smart Temperature Converter Utility  ---")
print("1. Convert Celsius to Fahrenheit")
print("2. Convert Fahrenheit to Celsius")
choice = input("Choose an option (1 or 2): ").strip()
if choice == "1":
    c_input = float(input("Enter temperature in Celsius: "))
    result = celsius_to_fahrenheit(c_input)
    print(f" Result: {c_input}°C is equal to {result:.2f}°F")
elif choice == "2":
    f_input = float(input("Enter temperature in Fahrenheit: "))
    result = fahrenheit_to_celsius(f_input)
    print(f" Result: {f_input}°F is equal to {result:.2f}°C")
else:
    print(" Invalid option chosen. Please run the program again.")
