print("--- Password Security Evaluator ---")
password = input("Enter a password to test: ")
password_length = len(password)

# Explicitly checking for specific character types
has_digit = any(char.isdigit() for char in password)
has_upper = any(char.isupper() for char in password)
has_lower = any(char.islower() for char in password)

# Checks if there's any character that isn't a letter or a number
has_special = any(not char.isalnum() for char in password) 

# Step 2: Count how many criteria are met
criteria_met = sum([has_digit, has_upper, has_lower, has_special])

# Step 3: Evaluate strength based on length AND character variety
if password_length < 6:
    strength = "🔴 Weak (Too short! Minimum 6 characters required)"
elif password_length >= 8 and criteria_met >= 3:
    strength = "🟢 Strong (Great length and excellent character variety!)"
elif password_length >= 6 and criteria_met >= 2:
    strength = "🟡 Medium (Good effort, but try adding more character types)"
else:
    strength = "🔴 Weak (Easy to guess. Mix up your characters!)"

# Display the evaluation
print("-----------------------------------")
print(f"Password Length: {password_length}")
print(f"Criteria Met:    {criteria_met}/4 (Digits, Upper, Lower, Special)")
print(f"Security Rating: {strength}")
print("-----------------------------------")
